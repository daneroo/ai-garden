{
  "name": "epub-inspect",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:browser": "bun build src/browser/entry.ts --target=browser --format=iife --outfile=dist/epubts-browser.js",
    "inspect": "bun run build:browser && bun run src/index.ts",
    "postinstall": "playwright install chromium",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@likecoin/epub-ts": "^0.6.7",
    "@storyteller-platform/epub": "^0.6.2",
    "@xmldom/xmldom": "^0.9.10",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12",
    "playwright": "^1.61.0"
  }
}
