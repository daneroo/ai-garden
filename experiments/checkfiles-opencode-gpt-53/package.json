{
  "name": "checkfiles-opencode-gpt-53",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "test": "bun --bun vitest run --reporter=verbose",
